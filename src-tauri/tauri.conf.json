{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimal Clock",
  "version": "0.1.3",
  "identifier": "com.local.minimal-clock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Minimal Clock",
        "url": "index.html",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "width": 300,
        "height": 300
      },
      {
        "label": "settings",
        "title": "Minimal Clock Settings",
        "url": "settings.html",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "width": 320,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "languages": [
          "Japanese",
          "English",
          "Spanish",
          "Italian",
          "French",
          "Russian",
          "SimpChinese",
          "Korean"
        ],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://minimal-clock-releases.s3.ap-northeast-1.amazonaws.com/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDN0VGOTg1RTM5RkI3QwpSV1I4K3psZW1PL0hDMFVVRjhFbTFUMkQwa3duTjNLUjhxeFJGbDZzUkVrKzlZQ1FlaWlZaDJZRQo="
    }
  }
}

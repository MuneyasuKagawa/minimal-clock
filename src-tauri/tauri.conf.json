{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimal Clock",
  "version": "0.1.0",
  "identifier": "com.local.minimal-clock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Minimal Clock",
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  }
}
